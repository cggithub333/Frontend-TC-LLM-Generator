# Backend API (server-side only — used by Next.js Route Handlers / Proxy)
BACKEND_API_URL=https://api.quraex.com/api/v1

# WebSocket URL (client-side — direct connection to backend STOMP broker)
NEXT_PUBLIC_WS_URL=https://api.quraex.com/ws

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
