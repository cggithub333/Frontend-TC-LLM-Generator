NEXT_PUBLIC_API_URL=http://localhost:3000

# Backend API (server-side only — used by Next.js Route Handlers)
# Local Docker dev: uses host.docker.internal to reach backend on host
# Production: change to your actual backend URL (e.g. https://api.yourapp.com/api/v1)
BACKEND_API_URL=http://localhost:8080/api/v1

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
